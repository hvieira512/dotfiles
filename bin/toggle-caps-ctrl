#!/usr/bin/env bash
# Toggle Caps Lock ↔ Left Control swap via keyd
set -e

KXKBRC="$HOME/.config/kxkbrc"
OPTION="ctrl:swapcaps"
SUDOERS_FILE="/etc/sudoers.d/setkeycodes"

SCRIPT_DIR="${BASH_SOURCE[0]%/*}"
KEYD_CONF_SRC="$(realpath "$SCRIPT_DIR/../keyd/default.conf" 2>/dev/null || echo "$SCRIPT_DIR/../keyd/default.conf")"

run_sudo() {
    if [ -f "$SUDOERS_FILE" ]; then
        sudo -n "$@" 2>/dev/null && return 0
    fi
    sudo "$@"
}

install_config() {
    if [ ! -f /etc/keyd/default.conf ] && [ -f "$KEYD_CONF_SRC" ]; then
        run_sudo mkdir -p /etc/keyd
        run_sudo cp "$KEYD_CONF_SRC" /etc/keyd/default.conf
    fi
}

update_kxkbrc() {
    if [ "$1" = add ]; then
        if [ -n "$CURRENT" ]; then
            new_opts="${CURRENT},${OPTION}"
        else
            new_opts="${OPTION}"
        fi
        sed -i '/^Options=/d' "$KXKBRC"
        sed -i "/^\[Layout\]/a Options=$new_opts" "$KXKBRC"
    else
        local rest
        rest=$(echo "$CURRENT" | tr ',' '\n' | grep -Fvx "$OPTION" | paste -sd ',' -)
        if [ -z "$rest" ]; then
            sed -i '/^Options=/d' "$KXKBRC"
        else
            sed -i "s/^Options=.*/Options=$rest/" "$KXKBRC"
        fi
    fi
}

install_config

ACTION="${1:-toggle}"

CURRENT=$(sed -n '/^\[Layout\]/,/^\[/{/^Options=/s/^Options=//p}' "$KXKBRC" 2>/dev/null)
has_option() { echo "$CURRENT" | tr ',' '\n' | grep -Fx "$OPTION" >/dev/null 2>&1; }

case "$ACTION" in
    on|--on)
        if ! has_option; then
            run_sudo systemctl start keyd
            update_kxkbrc add
            echo "Caps Lock ↔ Ctrl: ON"
        fi
        ;;
    off|--off)
        if has_option; then
            run_sudo systemctl stop keyd
            update_kxkbrc remove
            echo "Caps Lock ↔ Ctrl: OFF"
        fi
        ;;
    toggle|*)
        if has_option; then
            run_sudo systemctl stop keyd
            update_kxkbrc remove
            echo "Caps Lock ↔ Ctrl: OFF"
        else
            run_sudo systemctl start keyd
            update_kxkbrc add
            echo "Caps Lock ↔ Ctrl: ON"
        fi
        ;;
esac
